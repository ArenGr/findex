# PRODUCTION DEPLOYS: set APP_ENV=production and APP_DEBUG=false. The local
# values below are convenient for development but will leak full stack
# traces (including env values) to visitors if copied as-is into prod.
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# Add 'sentry' here (e.g. "single,sentry") once SENTRY_LARAVEL_DSN below is
# set, to get warning/error-level log entries and unhandled exceptions
# reported to Sentry instead of only being visible in the log file.
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Error monitoring (https://sentry.io) - leave empty to disable entirely.
SENTRY_LARAVEL_DSN=

# Set to your reverse proxy/load balancer IP(s) (comma-separated) or '*' if
# it's a trusted internal LB - required for correct HTTPS/IP detection when
# deployed behind one. Leave empty for a direct (no proxy) deployment.
TRUSTED_PROXIES=

# Optional dead-man's-switch URL (e.g. from healthchecks.io/Cronitor/Better
# Uptime) pinged every 5 minutes by the schedule - lets you get alerted if
# the server's cron entry ever stops firing. Leave empty to disable.
SCHEDULE_HEARTBEAT_URL=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=findex
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# predis is a pure-PHP client (no ext-redis/phpredis needed) - switch to
# 'phpredis' if that extension is confirmed installed on the host, it's
# faster, but predis works everywhere with zero extra setup.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=

# How many months of currency_rate_history/mortgage_offer_history to keep
# before the daily model:prune command deletes older rows.
HISTORY_RETENTION_MONTHS=24

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_GROUP_URL=
TELEGRAM_WEBHOOK_SECRET=

WHATSAPP_GROUP_URL=

VITE_APP_NAME="${APP_NAME}"
